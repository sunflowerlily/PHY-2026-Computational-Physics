ine":142,"column":1},"end":{"line":142,"column":1}},"children":[{"type":"text","value":"作用域 (Scope)","position":{"start":{"line":142,"column":1},"end":{"line":142,"column":1}},"key":"dBN6BGsI2T"}],"key":"ja5nehNJOe"},{"type":"text","value":"：函数内的变量是局部的。不要依赖全局变量（Global Variables），那是“幽灵超距作用”，是调试的噩梦。","position":{"start":{"line":142,"column":1},"end":{"line":142,"column":1}},"key":"bWkcHFFFfr"}],"key":"u4ltWs6deI"}],"key":"W1NK5wDUzW"}],"key":"eBC0tF3iNf"},{"type":"thematicBreak","position":{"start":{"line":144,"column":1},"end":{"line":144,"column":1}},"key":"PuB2JAmOtQ"},{"type":"heading","depth":2,"position":{"start":{"line":146,"column":1},"end":{"line":146,"column":1}},"children":[{"type":"text","value":"6. 类与对象 (OOP)：天体物理的抽象","position":{"start":{"line":146,"column":1},"end":{"line":146,"column":1}},"key":"uOzUUOe21M"}],"identifier":"id-6-oop","label":"6. 类与对象 (OOP)：天体物理的抽象","html_id":"id-6-oop","implicit":true,"key":"NcEoc8wYv9"},{"type":"paragraph","position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"children":[{"type":"text","value":"面向对象编程 (OOP) 非常适合描述具有内部状态和行为的物理实体。","position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"key":"iF5tOFseUB"}],"key":"vbAtpvM8fA"},{"type":"heading","depth":3,"position":{"start":{"line":150,"column":1},"end":{"line":150,"column":1}},"children":[{"type":"text","value":"6.1 抽象：以“行星”为例","position":{"start":{"line":150,"column":1},"end":{"line":150,"column":1}},"key":"hGuRyErJA0"}],"identifier":"id-6-1","label":"6.1 抽象：以“行星”为例","html_id":"id-6-1","implicit":true,"key":"daFNCNBVZQ"},{"type":"paragraph","position":{"start":{"line":151,"column":1},"end":{"line":151,"column":1}},"children":[{"type":"text","value":"一个行星有属性（质量、位置、速度）和行为（移动、受力）。","position":{"start":{"line":151,"column":1},"end":{"line":151,"column":1}},"key":"aIl3ylw1Mx"}],"key":"KRzLSpzmnk"},{"type":"code","lang":"python","value":"class Planet:\n    def __init__(self, name, mass, pos, vel):\n        \"\"\"构造函数：初始化行星状态\"\"\"\n        self.name = name\n        self.mass = mass\n        self.pos = np.array(pos, dtype=float)\n        self.vel = np.array(vel, dtype=float)\n        \n    def kinetic_energy(self):\n        \"\"\"计算动能\"\"\"\n        return 0.5 * self.mass * np.sum(self.vel**2)\n    \n    def update_position(self, dt):\n        \"\"\"时间演化：一阶欧拉法\"\"\"\n        self.pos += self.vel * dt\n\n# 实例化对象\nearth = Planet(\"Earth\", 5.97e24, [1.5e11, 0], [0, 30000])\n\nprint(f\"{earth.name} KE: {earth.kinetic_energy():.2e} J\")\nearth.update_position(3600) # 演化 1 小时","position":{"start":{"line":153,"column":1},"end":{"line":175,"column":1}},"key":"gFgypWjGG3"},{"type":"blockquote","position":{"start":{"line":177,"column":1},"end":{"line":178,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":177,"column":1},"end":{"line":178,"column":1}},"children":[{"type":"strong","position":{"start":{"line":177,"column":1},"end":{"line":177,"column":1}},"children":[{"type":"text","value":"思考","position":{"start":{"line":177,"column":1},"end":{"line":177,"column":1}},"key":"Gi8RJJ4cpV"}],"key":"frKaMblWWi"},{"type":"text","value":"：为什么在高性能计算（如 N-body）中，我们通常不使用这种“纯 OOP”结构（每个粒子一个对象），而是使用“数组结构”（Structure of Arrays, SoA）？\n","position":{"start":{"line":177,"column":1},"end":{"line":177,"column":1}},"key":"SrTgtfxm5B"},{"type":"emphasis","position":{"start":{"line":177,"column":1},"end":{"line":177,"column":1}},"children":[{"type":"text","value":"答案：因为 Python 对象开销太大，且无法利用 CPU 缓存和向量化指令。OOP 适合高层逻辑，底层计算还是得靠 Numpy 数组。","position":{"start":{"line":177,"column":1},"end":{"line":177,"column":1}},"key":"Lo6JH1dj66"}],"key":"eQaJ1H576J"}],"key":"zr6nF6fDQn"}],"key":"uwwsU9xKgt"},{"type":"thematicBreak","position":{"start":{"line":180,"column":1},"end":{"line":180,"column":1}},"key":"UxEekXorz8"}],"key":"Vh8iBVkeiA"}],"key":"pfWNEh4XSj"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"第 1 周：计算物理新范式 (The New Paradigm)","url":"/week01-paradigm","group":"计算物理学：从数值模拟