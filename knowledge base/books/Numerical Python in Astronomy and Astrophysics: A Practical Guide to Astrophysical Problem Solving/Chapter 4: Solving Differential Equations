M1 = 3.17 * M_sun.value    # Algol Aa1
M2 = 0.70 * M_sun.value    # Algol Aa2
M3 = 1.76 * M_sun.value    # Algol Ab

# inner orbit
T12 = 2.867 * day
e12 = 0

# outer orbit
